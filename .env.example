# Vercel Postgres (Neon-backed) — auto-injected when a Postgres database is connected to the Vercel project.
# Locally, copy this file to `.env.local` and paste the values from Vercel project → Storage → your DB → `.env.local` snippet.
DATABASE_URL=
DATABASE_URL_UNPOOLED=
PGHOST=
PGUSER=
PGPASSWORD=
PGDATABASE=

# (Optional) Legacy compat for old @vercel/postgres setups — same value as DATABASE_URL.
POSTGRES_URL=

# Auth.js — generate with `openssl rand -base64 32`. Used for session encryption.
AUTH_SECRET=

# Unifonic SMS (E1 phone OTP). Provision a sender ID + app SID in the Unifonic console.
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=

# Vercel Blob (avatars, civil ID images). Auto-injected when Blob store is connected.
BLOB_READ_WRITE_TOKEN=
