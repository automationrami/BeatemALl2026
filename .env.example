# Postgres connection — auto-injected by Vercel when a Postgres database is connected via the
# project's Storage tab (works for Neon, Supabase, Vercel Postgres, RDS Proxy marketplace integrations).
# Locally, run `vercel pull --environment=production` and the values land in `.vercel/.env.production.local`.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# (Aliases recognized by our client for portability across providers)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Auth.js — generate with `openssl rand -base64 32`. Used for session encryption.
AUTH_SECRET=

# Unifonic SMS (E1 phone OTP). Provision a sender ID + app SID in the Unifonic console.
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=

# Vercel Blob (avatars, civil ID images). Auto-injected when Blob store is connected.
BLOB_READ_WRITE_TOKEN=
